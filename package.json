{
  "name": "@jl-org/log",
  "version": "2.1.2",
  "description": "A beautiful, zero-dependency, cross-platform logger for Browser & Node.js — colorful output, unified API, full TypeScript types.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/typings/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./node": {
      "require": {
        "types": "./dist/node/typings/node/index.d.ts",
        "default": "./dist/node/index.cjs"
      },
      "import": {
        "types": "./dist/node/typings/node/index.d.ts",
        "default": "./dist/node/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rollup -c && tsc-alias",
    "build:dev": "cross-env NODE_ENV=development rollup -c && tsc-alias",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:browser": "start ./test/browser.html",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "log",
    "logger",
    "logging",
    "console",
    "color",
    "colorful",
    "ansi",
    "terminal",
    "browser",
    "nodejs",
    "node",
    "cross-platform",
    "isomorphic",
    "typescript",
    "zero-dependency",
    "pretty-print",
    "progress-bar"
  ],
  "author": "CJL <2662442385@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/beixiyo/jl-log#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beixiyo/jl-log.git"
  },
  "bugs": {
    "url": "https://github.com/beixiyo/jl-log/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "packageManager": "pnpm@10.24.0",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "rotating-file-stream": "^3"
  },
  "peerDependenciesMeta": {
    "rotating-file-stream": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.0.0",
    "jsdom": "^29.1.1",
    "rollup": "^4.16.1",
    "rollup-plugin-clear": "^2.0.7",
    "rotating-file-stream": "^3.2.9",
    "tsc-alias": "^1.8.8",
    "tslib": "^2.6.2",
    "vitest": "^4.1.9"
  }
}
